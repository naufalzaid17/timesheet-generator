# Backend configuration (copy to .env or export in your environment).

# HTTP
PORT=8080
GIN_MODE=debug

# PostgreSQL
DATABASE_URL=host=localhost user=timesheet password=timesheet dbname=timesheet port=5432 sslmode=disable TimeZone=Asia/Jakarta

# JWT session tokens. REQUIRED in production (GIN_MODE=release): the server
# refuses to boot if this is empty or a known-weak placeholder. Generate one
# with e.g. `openssl rand -hex 32`.
JWT_SECRET=
JWT_EXPIRY_HOURS=24
RESET_TOKEN_TTL_MINUTES=60

# WebAuthn relying party (origin(s) must match the frontend origin).
# WEBAUTHN_RP_ORIGIN accepts a comma-separated list to allow passkeys across
# multiple domains, e.g. "https://app.example.com,https://timesheet.example.org".
WEBAUTHN_RP_NAME=Timesheet Portal
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# SMTP (Mailpit defaults for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Timesheet Portal <no-reply@timesheet.local>

# Web Push VAPID keys. Leave blank to auto-generate at boot (logged to stdout);
# pin a stable pair in production so subscriptions survive restarts.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@timesheet.local

# Reminder scheduler timezone (WIB)
SCHEDULER_TZ=Asia/Jakarta

# Links inside outgoing email
FRONTEND_URL=http://localhost:3000

# Bootstrap admin (created once when the users table is empty). Leave the
# password blank to have a strong random one generated and printed to the logs
# on first boot; set it to choose your own.
BOOTSTRAP_ADMIN_EMAIL=admin@timesheet.local
BOOTSTRAP_ADMIN_USERNAME=admin
# Leave blank to have a strong NIST SP 800-63B-compliant password generated and
# logged once on first boot. If set, it must satisfy the same policy (>= 8 chars,
# not a common/blocked value, not derived from the username/email).
BOOTSTRAP_ADMIN_PASSWORD=
