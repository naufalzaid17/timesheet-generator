FROM golang:1.25-alpine

# git for module fetches, tzdata so Asia/Jakarta (WIB) resolves for the cron.
RUN apk update && apk add --no-cache git tzdata

# Air for Go hot-reloading (air-verse is the maintained module path).
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Copy dependency files and pre-download modules.
COPY go.mod go.sum* ./
RUN go mod download || true

EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
