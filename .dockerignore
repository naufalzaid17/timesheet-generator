# Keep the Docker build context small and reproducible. Dependencies are
# installed inside the image; build artifacts are regenerated there.

.git
**/.git

# Node / Next
frontend/node_modules
**/node_modules
frontend/.next
frontend/out
frontend/*.tsbuildinfo

# Go build artifacts
backend/tmp
backend/main

# Local env / editor / OS
**/.env
**/.env.local
.vscode
.idea
.DS_Store
*.log
